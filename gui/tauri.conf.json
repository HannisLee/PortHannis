{
  "productName": "PortHannis",
  "version": "0.3.0",
  "identifier": "com.porthannis.gui",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:25879"
  },
  "app": {
    "windows": [
      {
        "title": "PortHannis",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
